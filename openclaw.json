{
  "meta": {
    "lastTouchedVersion": "2026.1.29"
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "models": {
    "providers": {
      "budget-model": {
        "baseUrl": "${BUDGET_MODEL_BASE_URL}",
        "apiKey": "${BUDGET_MODEL_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "${BUDGET_MODEL_ID}", "name": "Budget Model", "contextWindow": 32768 }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/app/workspace-lead-agent",
      "identity": "/app/identity",
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 20000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 40000,
          "systemPrompt": "Session nearing compaction. Store durable memories now.",
          "prompt": "Write any lasting notes to memory/YYYY-MM-DD.md. Focus on: key decisions made, current project status, tasks completed, lessons learned, and active blockers. Reply with NO_REPLY if nothing to store."
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "6h",
        "keepLastAssistants": 3
      },
      "memorySearch": {
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        },
        "experimental": {
          "sessionMemory": true
        },
        "sources": ["memory", "sessions"]
      },
      "maxConcurrent": 6,
      "subagents": {
        "maxConcurrent": 10
      }
    },
    "list": [
      {
        "id": "lead-agent",
        "default": true,
        "workspace": "/app/workspace-lead-agent",
        "model": "anthropic/claude-opus-4-6",
        "name": "Lead Agent",
        "subagents": {
          "allowAgents": ["engineer-agent", "devops-agent"]
        }
      },
      {
        "id": "engineer-agent",
        "workspace": "/app/workspace-engineer-agent",
        "model": "anthropic/claude-sonnet-4-6",
        "name": "Engineer Agent"
      },
      {
        "id": "devops-agent",
        "workspace": "/app/workspace-devops-agent",
        "model": "anthropic/claude-sonnet-4-6",
        "name": "DevOps Agent"
      },
      {
        "id": "ops-monitor",
        "workspace": "/app/workspace-ops-monitor",
        "model": "anthropic/claude-haiku-4-5-20251001",
        "name": "Ops Monitor"
      },
      {
        "id": "docs-agent",
        "workspace": "/app/workspace-docs-agent",
        "model": "anthropic/claude-sonnet-4-6",
        "name": "Documentation Agent"
      }
    ]
  },
  "bindings": [
    {
      "agentId": "lead-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_TASKS_CHANNEL_ID}" } }
    },
    {
      "agentId": "lead-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_WORK_CHANNEL_ID}" } }
    },
    {
      "agentId": "lead-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_REVIEWS_CHANNEL_ID}" } }
    },
    {
      "agentId": "lead-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_ALERTS_CHANNEL_ID}" } }
    },
    {
      "agentId": "engineer-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_WORK_CHANNEL_ID}" } }
    },
    {
      "agentId": "devops-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_WORK_CHANNEL_ID}" } }
    },
    {
      "agentId": "devops-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_ALERTS_CHANNEL_ID}" } }
    },
    {
      "agentId": "docs-agent",
      "match": { "channel": "discord", "peer": { "kind": "channel", "id": "${DISCORD_DEV_WORK_CHANNEL_ID}" } }
    }
  ],
  "tools": {
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    },
    "agentToAgent": {
      "enabled": true,
      "allow": ["lead-agent", "engineer-agent", "devops-agent", "ops-monitor", "docs-agent"]
    },
    "web": {
      "search": {
        "apiKey": "${WEB_SEARCH_API_KEY}"
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "open",
      "guilds": {
        "${DISCORD_GUILD_ID}": {
          "requireMention": false
        }
      }
    }
  },
  "gateway": {
    "port": 18790,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_AUTH_TOKEN}"
    }
  },
  "plugins": {
    "entries": {
      "discord": {
        "enabled": true
      }
    }
  }
}
