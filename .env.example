# ============================================================
# Multi-Agent Team — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Core (Required) ---
ANTHROPIC_TOKEN=your-anthropic-api-key
GATEWAY_AUTH_TOKEN=any-random-string-for-gateway-auth

# --- Discord (Required for chat integration) ---
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-discord-server-id
DISCORD_DEV_TASKS_CHANNEL_ID=channel-id-for-task-intake
DISCORD_DEV_WORK_CHANNEL_ID=channel-id-for-main-coordination
DISCORD_DEV_REVIEWS_CHANNEL_ID=channel-id-for-code-reviews
DISCORD_DEV_ALERTS_CHANNEL_ID=channel-id-for-alerts

# --- Git Provider (Required for MR/PR automation) ---
# Supports: github, gitlab, bitbucket
GIT_PROVIDER=github
GIT_API_URL=https://api.github.com
GIT_API_TOKEN=your-git-api-token
# Project IDs (GitHub: owner/repo, GitLab: numeric ID)
PROJECT_1_ID=your-org/your-app
PROJECT_1_NAME=Your App
# PROJECT_2_ID=your-org/your-api
# PROJECT_2_NAME=Your API

# --- Budget Model for Ops Monitor (Optional) ---
# Use a cheap model for routine monitoring crons to save cost.
# If not set, ops-monitor will use Anthropic Haiku (already configured).
# Example: Nebius Token Factory (OpenAI-compatible)
# BUDGET_MODEL_API_KEY=your-budget-model-api-key
# BUDGET_MODEL_PROVIDER=openai
# BUDGET_MODEL_BASE_URL=https://api.tokenfactory.nebius.com/v1
# BUDGET_MODEL_ID=Qwen/Qwen3-30B-A3B-Instruct-2507

# --- Web Search (Optional) ---
# WEB_SEARCH_API_KEY=your-web-search-api-key

# --- Database (If your app uses one) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# --- Test Runner (Optional — for E2E tests) ---
# TEST_COMMAND=npx playwright test
# TESTS_DIR=/path/to/your/tests
# E2E_BASE_URL=http://localhost:3000

# --- Microsoft Teams (Optional — for daily summaries) ---
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# --- Docs Repo (Optional — for docs-agent) ---
# GITHUB_DOCS_TOKEN=your-github-token-with-repo-access
# DOCS_REPO_URL=https://github.com/your-org/your-docs.git

# --- Code Graph (Optional — Layer 5) ---
# Repos to index (absolute paths on your server)
# REPO_1_PATH=/path/to/your/app
# REPO_2_PATH=/path/to/your/api
